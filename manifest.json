{
    "name": "Hello Extensions",
    "description": "Base Level Extension",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": [
        "scripting",
        "activeTab"
    ],
    "action": {
        "default_popup": "hello.html",
        "default_icon": "hello_extensions.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://dictionary.cambridge.org/*"
            ],
            "css": [],
            "js": [
                "js/jquery.min.js",
                "js/dictionary.cambridge.org.js"
            ],
            "all_frames": false,
            "match_origin_as_fallback": false,
            "match_about_blank": false,
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://google.com/*",
                "https://google.com.vn/*",
                "https://www.google.com/*",
                "https://www.google.com.vn/*"
            ],
            "css": [],
            "js": [
                "js/jquery.min.js",
                "js/google.com.js"
            ],
            "all_frames": false,
            "match_origin_as_fallback": false,
            "match_about_blank": false,
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://*.databases.neo4j.io/browser/",
                "https://console-preview.neo4j.io/tools/query",
                "https://www.console-preview.neo4j.io/tools/query"
            ],
            "css": [],
            "js": [
                "js/jquery.min.js",
                "js/neo4j.io.js"
            ],
            "all_frames": false,
            "match_origin_as_fallback": false,
            "match_about_blank": false,
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://*.ldoceonline.com/*"
            ],
            "css": [],
            "js": [
                "js/jquery.min.js",
                "js/ldoceonline.com.js"
            ],
            "all_frames": false,
            "match_origin_as_fallback": false,
            "match_about_blank": false,
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://*.oxfordlearnersdictionaries.com/*"
            ],
            "css": [],
            "js": [
                "js/jquery.min.js",
                "js/oxfordlearnersdictionaries.com.js"
            ],
            "all_frames": false,
            "match_origin_as_fallback": false,
            "match_about_blank": false,
            "run_at": "document_idle"
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "css": [],
            "js": [
                "js/jquery.min.js",
                "js/ad-killer.js"
            ],
            "all_frames": false,
            "match_origin_as_fallback": false,
            "match_about_blank": false,
            "run_at": "document_idle"
        }
    ]
}